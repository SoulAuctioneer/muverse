# LLM Provider Keys (litellm supports 100+ providers — set whichever you use)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Default model per agent role (any litellm-compatible model string)
# Examples: gemini/gemini-2.5-pro, anthropic/claude-sonnet-4-20250514, openai/gpt-4o
MODEL_THEORIST=gemini/gemini-2.5-pro
MODEL_CRITIC=gemini/gemini-2.5-pro
MODEL_LITERATURE=gemini/gemini-2.5-flash
MODEL_SIMULATOR=gemini/gemini-2.5-pro
MODEL_WRITER=gemini/gemini-2.5-pro
MODEL_ORCHESTRATOR=gemini/gemini-2.5-flash

# PostgreSQL (local Docker instance — see docker-compose.yml)
DATABASE_URL=postgresql://muverse:muverse@localhost:5432/muverse

# App
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
